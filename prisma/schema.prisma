generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgres"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Users {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  user_name String
  role      Role       @default(USER)
  comments  Comments[]
  posts     Posts[]

  @@map("users")
}

model Posts {
  id       String     @id @default(uuid())
  title    String
  content  String
  files    String[]
  user_id  String?
  comments Comments[]
  users    Users?     @relation(fields: [user_id], references: [id])

  @@map("posts")
}

model Comments {
  id      String  @id @default(uuid())
  comment String
  post_id String?
  user_id String
  posts   Posts?  @relation(fields: [post_id], references: [id])
  user    Users   @relation(fields: [user_id], references: [id])

  @@map("comments")
}

enum Role {
  USER
  ADMIN
}
