{
  "name": "e-commerce-back-end",
  "version": "1.0.0",
  "main": "server.js",
  "author": "Julio Lima Costa Valladares <juliolima1225@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev:server": "ts-node-dev --respawn --ignore-watch=node_modules --transpile-only src/server.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "start": "node build/server.js",
    "build": "tsc && npx prisma generate",
    "seed": "ts-node prisma/seed.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:migrate": "docker compose exec api npx prisma migrate dev",
    "docker:seed": "docker compose exec api npm run seed",
    "docker:setup": "docker compose up -d && sleep 3 && docker compose exec api npx prisma migrate dev && docker compose exec api npm run seed",
    "docker:restart": "docker compose restart"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/body-parser": "^1.19.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "prisma": "^4.16.2",
    "ts-node": "10.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^4.16.2",
    "@supabase/supabase-js": "^2.104.1",
    "axios": "^1.18.1",
    "bcrypt": "^5.1.0",
    "body-parser": "^1.20.1",
    "cors": "^2.8.6",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "form-data": "^4.0.6",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "pg": "^8.4.0",
    "reflect-metadata": "^0.1.13",
    "typeorm": "0.3.11"
  }
}
